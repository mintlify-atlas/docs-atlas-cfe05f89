{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TruequeU",
  "theme": "almond",
  "colors": {
    "primary": "#747474",
    "light": "#0b0b0b",
    "dark": "#b5b5b5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/a2d5ce6a-e228-43ef-b15c-6aaf770efc04.svg",
    "dark": "https://media.brand.dev/a2d5ce6a-e228-43ef-b15c-6aaf770efc04.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/DuqueJR/TruequeU"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/DuqueJR/TruequeU"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "getting-started"]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/listings",
              "features/create-listing",
              "features/chat",
              "features/profile",
              "features/favorites"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/sign-up",
              "account/login"
            ]
          }
        ]
      },
      {
        "tab": "Technical Reference",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "reference/architecture",
              "reference/state-management",
              "reference/routing"
            ]
          },
          {
            "group": "Data & Services",
            "pages": [
              "reference/data-types",
              "reference/auth-service",
              "reference/listing-service"
            ]
          }
        ]
      }
    ]
  }
}
